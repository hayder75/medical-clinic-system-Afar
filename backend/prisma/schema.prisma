generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                      @id @default(uuid())
  fullname                   String
  username                   String                      @unique
  password                   String
  email                      String?                     @unique
  phone                      String?
  role                       Role
  qualifications             String[]
  specialty                  String?
  licenseNumber              String?
  availability               Boolean                     @default(true)
  isActive                   Boolean                     @default(true)
  consultationFee            Float?
  waiveConsultationFee       Boolean                     @default(false)
  requiredCardType           String?                     @default("GENERAL")
  passwordChangedAt          DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  accountDeposits            AccountDeposit[]
  accountRequestsCreated     AccountRequest[]            @relation("AccountRequestsCreated")
  accountRequestsVerified    AccountRequest[]            @relation("AccountRequestsVerified")
  accountTransactions        AccountTransaction[]
  appointmentsCreated        Appointment[]               @relation("AppointmentCreator")
  appointments               Appointment[]               @relation("DoctorAppointments")
  assignments                Assignment[]
  auditLogs                  AuditLog[]
  bankDeposits               BankDeposit[]
  batchOrders                BatchOrder[]
  billingCreated             Billing[]                @relation("BillingCreator")
  billPaymentsCreated        BillPayment[]            @relation("BillPaymentCreator")
  cardActivations            CardActivation[]            @relation("CardActivations")
  cashExpenses               CashExpense[]
  cashTransactions           CashTransaction[]
  customMedications          CustomMedication[]          @relation("CustomMedications")
  cashSessionsCreated        DailyCashSession[]
  cashSessionsReset          DailyCashSession[]          @relation("CashSessionReset")
  dentalPhotos               DentalPhoto[]
  dentalProcedureCompletions DentalProcedureCompletion[]
  dentalRecords              DentalRecord[]
  diagnosisNotes             DiagnosisNotes[]
  diagnoses                  PatientDiagnosis[]
  dispenseLogs               DispenseLog[]
  emergencyDrugOrders        EmergencyDrugOrder[]        @relation("EmergencyDrugOrders")
  labOrders                  LabOrder[]
  labTestOrders              LabTestOrder[]
  loansGiven                 Loan[]                      @relation("LoansGiven")
  loansReviewed              Loan[]                      @relation("LoansReviewed")
  loansSettled               Loan[]                      @relation("LoansSettled")
  loansSettlementAccepted    Loan[]                      @relation("LoansSettlementAccepted")
  loansRequested             Loan[]                      @relation("LoansRequested")
  materialNeedsOrders        MaterialNeedsOrder[]        @relation("MaterialNeedsOrders")
  medicalCertificates        MedicalCertificate[]
  medicalHistories           MedicalHistory[]            @relation("DoctorHistory")
  orders                     MedicationOrder[]
  nurseAdministrations       NurseAdministration[]
  nurseAssignmentsBy         NurseServiceAssignment[]    @relation("NurseAssignmentsBy")
  nurseAssignments           NurseServiceAssignment[]    @relation("NurseAssignments")
  nurseWalkInOrders          NurseWalkInOrder[]          @relation("NurseWalkInOrders")
  doctorWalkInOrders         DoctorWalkInOrder[]         @relation("DoctorWalkInOrders")
  verifiedAccounts           PatientAccount[]            @relation("VerifiedAccounts")
  attachedImages             PatientAttachedImage[]
  galleryUploads             PatientGallery[]
  radiologyOrders            RadiologyOrder[]
  systemSettingsUpdated      SystemSettings[]            @relation("SystemSettingsUpdated")
  visits                     Visit[]
  referrals                  Referral[]
  internationalMedicalCertificates InternationalMedicalCertificate[]
  admissionsCreated          Admission[]                 @relation("AdmissionsCreated")
  admissionServicesOrdered   AdmissionService[]          @relation("AdmissionServicesOrdered")
  compoundPrescriptions      CompoundPrescription[]
  externalDiagnosticOrders   ExternalDiagnosticOrder[]
  transfersInitiated         PatientTransfer[]            @relation("TransferFromDoctor")
  transfersReceived          PatientTransfer[]            @relation("TransferToDoctor")
  commissions                DoctorCommission[]

  @@index([role])
  @@index([availability])
  @@index([email])
  @@index([username])
  @@index([fullname])
}

model Service {
  id                      String                   @id @default(uuid())
  code                    String                   @unique
  name                    String
  category                ServiceCategory
  price                   Float
  unit                    String?                  @default("UNIT")
  description             String?
  isActive                Boolean                  @default(true)
  isVariablePrice         Boolean                  @default(false)
  minPrice                Float?
  maxPrice                Float?
  procedureGroup          String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  batchOrderServices      BatchOrderService[]
  billingServices         BillingService[]
  emergencyDrugOrders     EmergencyDrugOrder[]
  inventoryItems          Inventory[]
  investigationTypes      InvestigationType[]
  labTests                LabTest[]
  materialNeedsOrders     MaterialNeedsOrder[]
  nurseServiceAssignments NurseServiceAssignment[]
  nurseWalkInOrders       NurseWalkInOrder[]
  doctorWalkInOrders      DoctorWalkInOrder[]
  admissionServices       AdmissionService[]
}

model Insurance {
  id           String                 @id @default(uuid())
  name         String
  code         String                 @unique
  contactInfo  String?
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  billPayments BillPayment[]
  billings     Billing[]
  transactions InsuranceTransaction[]
  patients     Patient[]
}

model BillingService {
  id         String   @id @default(uuid())
  billingId  String
  serviceId  String
  quantity   Int      @default(1)
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())
  billing    Billing  @relation(fields: [billingId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])

  @@unique([billingId, serviceId])
}

model Patient {
  id                         String                      @id
  name                       String
  dob                        DateTime?
  age                        Int?
  gender                     Gender?
  type                       PatientType
  mobile                     String?
  email                      String?
  address                    String?
  region                     String?
  zone                       String?
  woreda                     String?
  kebele                     String?
  nationalId                 String?
  emergencyContact           String?
  bloodType                  BloodType?
  maritalStatus              MaritalStatus?
  disabilityStatus           DisabilityStatus?
  status                     PatientStatus               @default(Active)
  insuranceId                String?
  cardStatus                 CardStatus                  @default(INACTIVE)
   cardType                   String                      @default("GENERAL")
  cardActivatedAt            DateTime?
  cardExpiryDate             DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  accountDeposits            AccountDeposit[]
  accountRequests            AccountRequest[]            @relation("AccountRequestPatient")
  accountTransactions        AccountTransaction[]
  appointments               Appointment[]
  assignments                Assignment[]
  batchOrders                BatchOrder[]
  payments                   BillPayment[]
  bills                      Billing[]
  cardActivations            CardActivation[]
  cashTransactions           CashTransaction[]
  dentalPhotos               DentalPhoto[]
  dentalProcedureCompletions DentalProcedureCompletion[]
  dentalRecords              DentalRecord[]
  diagnosisNotes             DiagnosisNotes[]
  diagnoses                  PatientDiagnosis[]
  dispenseLogs               DispenseLog[]
  emergencyDrugOrders        EmergencyDrugOrder[]
  files                      File[]
  insuranceTransactions      InsuranceTransaction[]
  labOrders                  LabOrder[]
  labTestOrders              LabTestOrder[]
  materialNeedsOrders        MaterialNeedsOrder[]
  medicalCertificates        MedicalCertificate[]
  history                    MedicalHistory[]            @relation("PatientHistory")
  orders                     MedicationOrder[]
  nurseWalkInOrders          NurseWalkInOrder[]
  doctorWalkInOrders         DoctorWalkInOrder[]
  compoundPrescriptions      CompoundPrescription[]
  externalDiagnosticOrders   ExternalDiagnosticOrder[]
  insurance                  Insurance?                  @relation(fields: [insuranceId], references: [id])
  patientAccount             PatientAccount?
  attachedImages             PatientAttachedImage[]
  galleryImages              PatientGallery[]
  pharmacyInvoices           PharmacyInvoice[]
  radiologyOrders            RadiologyOrder[]
  virtualQueues              VirtualQueue[]
  visits                     Visit[]
  vitals                     VitalSign[]
  referrals                  Referral[]
  internationalMedicalCertificates InternationalMedicalCertificate[]
  admissions                 Admission[]
  patientTransfers           PatientTransfer[]

  @@index([status])
  @@index([type])
  @@index([insuranceId])
  @@index([createdAt])
  @@index([cardStatus])
  @@index([name])
  @@index([mobile])
}

model Visit {
  id                         Int                         @id @default(autoincrement())
  visitUid                   String                      @unique
  patientId                  String
  createdById                String?
  suggestedDoctorId          String?
  date                       DateTime                    @default(now())
  status                     VisitStatus                 @default(WAITING_FOR_TRIAGE)
  queueType                  QueueType                   @default(CONSULTATION)
  isEmergency                Boolean                     @default(false)
  notes                      String?
  diagnosis                  String?
  diagnosisDetails           String?
  outcome                    String?
  instructions               String?
  assignmentId               Int?
  cardProductId              String?
  parentVisitId              Int?
  completedAt                DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  accountTransactions        AccountTransaction[]        @relation("AccountTransactionVisit")
  batchOrders                BatchOrder[]
  bills                      Billing[]
  dentalPhotos               DentalPhoto[]
  dentalProcedureCompletions DentalProcedureCompletion[]
  dentalRecords              DentalRecord[]
  patientDiagnoses           PatientDiagnosis[]
  diagnosisNotes             DiagnosisNotes[]
  emergencyDrugOrders        EmergencyDrugOrder[]
  insuranceTransactions      InsuranceTransaction[]
  labOrders                  LabOrder[]
  labTestOrders              LabTestOrder[]
  materialNeedsOrders        MaterialNeedsOrder[]
  medicalCertificates        MedicalCertificate[]
  medicalHistories           MedicalHistory[]            @relation("VisitHistory")
  medicationOrders           MedicationOrder[]
  nurseServiceAssignments    NurseServiceAssignment[]
  attachedImages             PatientAttachedImage[]
  galleryImages              PatientGallery[]
  pharmacyInvoices           PharmacyInvoice[]
  radiologyOrders            RadiologyOrder[]
  createdBy                  User?                       @relation(fields: [createdById], references: [id])
  patient                    Patient                     @relation(fields: [patientId], references: [id])
  vitals                     VitalSign[]
  referrals                  Referral[]
  internationalMedicalCertificates InternationalMedicalCertificate[]
  nurseWalkInOrders              NurseWalkInOrder[]
  doctorWalkInOrders             DoctorWalkInOrder[]
  compoundPrescriptions         CompoundPrescription[]
  externalDiagnosticOrders      ExternalDiagnosticOrder[]
  parentVisit                  Visit?                      @relation("VisitSubVisits", fields: [parentVisitId], references: [id])
  subVisits                    Visit[]                     @relation("VisitSubVisits")
  transfersFrom                PatientTransfer[]           @relation("TransferFromVisit")
  transfersTo                  PatientTransfer[]           @relation("TransferToVisit")

  @@index([status])
  @@index([patientId])
  @@index([assignmentId])
  @@index([createdAt])
  @@index([suggestedDoctorId])
  @@index([status, assignmentId])
  @@index([status, patientId])
  @@index([status, createdAt])
}

model NurseServiceAssignment {
  id              Int                @id @default(autoincrement())
  visitId         Int
  serviceId       String
  assignedNurseId String
  assignedById    String
  status          NurseServiceStatus @default(PENDING)
  notes           String?
  orderType       String?            @default("TRIAGE_ORDERED")
  isWaived        Boolean            @default(false)
  waivedBy        String?
  waivedAt        DateTime?
  completedAt     DateTime?
  customPrice     Float?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  assignedBy      User               @relation("NurseAssignmentsBy", fields: [assignedById], references: [id])
  assignedNurse   User               @relation("NurseAssignments", fields: [assignedNurseId], references: [id])
  service         Service            @relation(fields: [serviceId], references: [id])
  visit           Visit              @relation(fields: [visitId], references: [id])

  @@index([visitId])
  @@index([assignedNurseId])
  @@index([status])
  @@index([createdAt])
}

model VitalSign {
  id                      Int      @id @default(autoincrement())
  patientId               String
  visitId                 Int?
  recordedByRole          String   @default("NURSE") // NURSE or DOCTOR
  bloodPressure           String?
  temperature             Float?
  tempUnit                TempUnit @default(C)
  heartRate               Int?
  respirationRate         Int?
  height                  Float?
  weight                  Float?
  bmi                     Float?
  oxygenSaturation        Int?
  condition               String?
  notes                   String?
  painScoreRest           Int?
  painScoreMovement       Int?
  sedationScore           Int?
  gcsEyes                 Int?
  gcsVerbal               Int?
  gcsMotor                Int?
  bloodPressureSystolic   Int?
  bloodPressureDiastolic  Int?
  chiefComplaint          String?
  historyOfPresentIllness String?
  onsetOfSymptoms         String?
  durationOfSymptoms      String?
  severityOfSymptoms      String?
  associatedSymptoms      String?
  relievingFactors        String?
  aggravatingFactors     String?
  generalAppearance      String?
  headAndNeck            String?
  cardiovascularExam     String?
  respiratoryExam        String?
  abdominalExam          String?
  extremities            String?
  neurologicalExam       String?
  gcsTotal               Int?
  mewsScore              Int?
  qsofaScore             Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  patient                Patient  @relation(fields: [patientId], references: [id])
  visit                  Visit?   @relation(fields: [visitId], references: [id])
}

model Appointment {
  id               Int               @id @default(autoincrement())
  patientId        String
  doctorId         String
  appointmentDate  DateTime
  appointmentTime  String
  type             AppointmentType   @default(CONSULTATION)
  status           AppointmentStatus @default(SCHEDULED)
  duration         String?
  notes            String?
  reason           String?
  createdById      String
  lastDiagnosedBy  String?
  visitId          Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        User              @relation("AppointmentCreator", fields: [createdById], references: [id])
  doctor           User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient          Patient           @relation(fields: [patientId], references: [id])
  medicalHistories MedicalHistory[]  @relation("AppointmentHistory")

  @@index([patientId])
  @@index([doctorId])
  @@index([createdById])
  @@index([appointmentDate])
  @@index([status])
}

model Billing {
  id                  String               @id @default(uuid())
  patientId           String
  visitId             Int?
  insuranceId         String?
  totalAmount         Float
  paidAmount          Float                @default(0)
  discount            Float                @default(0)
  isDeferred          Boolean              @default(false)
  status              BillingStatus        @default(PENDING)
  billingType         BillingType          @default(REGULAR)
  notes               String?
  createdById         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accountTransactions AccountTransaction[] @relation("AccountTransactionBilling")
  payments            BillPayment[]
  insurance           Insurance?           @relation(fields: [insuranceId], references: [id])
  patient             Patient              @relation(fields: [patientId], references: [id])
  visit               Visit?               @relation(fields: [visitId], references: [id])
  services            BillingService[]
  cardActivations     CardActivation[]     @relation("CardActivationBilling")
  cashTransactions    CashTransaction[]
  labOrders           LabOrder[]
  labTestOrders       LabTestOrder[]
  createdBy           User?                @relation("BillingCreator", fields: [createdById], references: [id])
}

model BillPayment {
  id          String      @id @default(uuid())
  billingId   String
  patientId   String
  amount      Float
  type        PaymentType
  bankName    String?
  transNumber String?
  insuranceId String?
  notes       String?
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  billing     Billing     @relation(fields: [billingId], references: [id])
  insurance   Insurance?  @relation(fields: [insuranceId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])
  createdBy   User?       @relation("BillPaymentCreator", fields: [createdById], references: [id])
}

model PharmacyInvoice {
  id                   String                @id @default(uuid())
  patientId            String?
  visitId              Int?
  invoiceNumber        String?
  totalAmount          Float
  status               BillingStatus         @default(PENDING)
  type                 PharmacyInvoiceType   @default(DOCTOR_PRESCRIPTION)
  paymentMethod        PaymentType?
  insuranceId          String?
  notes                String?
  createdBy            String?
  processedBy          String?
  processedAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  dispensedMedicines   DispensedMedicine[]
  patient              Patient?              @relation(fields: [patientId], references: [id])
  visit                Visit?                @relation(fields: [visitId], references: [id])
  pharmacyInvoiceItems PharmacyInvoiceItem[]
}

model PharmacyInvoiceItem {
  id                  String             @id @default(uuid())
  pharmacyInvoiceId   String
  medicationOrderId   Int?
  medicationCatalogId String?
  name                String
  dosageForm          String
  strength            String
  quantity            Int
  unitPrice           Float
  totalPrice          Float
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  medicationCatalog   MedicationCatalog? @relation(fields: [medicationCatalogId], references: [id])
  medicationOrder     MedicationOrder?   @relation(fields: [medicationOrderId], references: [id])
  pharmacyInvoice     PharmacyInvoice    @relation(fields: [pharmacyInvoiceId], references: [id])
}

model DispensedMedicine {
  id                  Int                @id @default(autoincrement())
  pharmacyInvoiceId   String
  medicationOrderId   Int?
  medicationCatalogId String?
  status              DispensedStatus
  name                String?
  dosageForm          String?
  strength            String?
  quantity            Int?
  unitPrice           Float?
  notes               String?
  dispensedAt         DateTime           @default(now())
  dispensedBy         String?
  medicationCatalog   MedicationCatalog? @relation(fields: [medicationCatalogId], references: [id])
  medicationOrder     MedicationOrder?   @relation(fields: [medicationOrderId], references: [id])
  pharmacyInvoice     PharmacyInvoice    @relation(fields: [pharmacyInvoiceId], references: [id])
}

model MedicationOrder {
  id                   Int                   @id @default(autoincrement())
  visitId              Int
  patientId            String
  doctorId             String
  medicationCatalogId  String?
  name                 String
  genericName          String?
  normalizedName       String?
  dosageFormCategory   String?
  dosageForm           String
  strength             String
  strengthText         String?
  instructionText      String?
  quantity             String?
  quantityNumeric      Float?
  calculatedQuantity   Float?
  finalQuantity        Float?
  quantityOverridden   Boolean               @default(false)
  unit                 String?
  frequencyType        String?
  frequencyValue       Float?
  frequencyUnit        String?
  frequencyText        String?
  duration             String?
  durationValue        Float?
  durationUnit         String?
  durationText         String?
  routeCode            String?
  route                String?
  instructions         String?
  additionalNotes      String?
  category             String?
  type                 String?
  unitPrice            Float?
  rxnormCode           String?
  atcCode             String?
  snomedCode          String?
  status               OrderStatus           @default(UNPAID)
  isDeferred           Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  continuousInfusion   ContinuousInfusion?
  dispenseLogs         DispenseLog[]
  dispensedMedicines   DispensedMedicine[]
  doctor               User                  @relation(fields: [doctorId], references: [id])
  medicationCatalog    MedicationCatalog?    @relation(fields: [medicationCatalogId], references: [id])
  patient              Patient               @relation(fields: [patientId], references: [id])
  visit                Visit                 @relation(fields: [visitId], references: [id])
  pharmacyInvoiceItems PharmacyInvoiceItem[]
}

model CompoundPrescription {
  id                    Int       @id @default(autoincrement())
  visitId               Int
  patientId             String
  doctorId              String

  // Free-text prescription (new simplified format)
  prescriptionText      String?
  rawText               String?

  // Formulation
  formulationType       String?   // CREAM, OINTMENT, GEL, LOTION, FOAM, SOLUTION

  // Base
  baseType             String?
  customBase           String?

  // Quantity
  quantity             Int?
  quantityUnit         String?   // g, ml

  // Directions
  frequencyType        String?
  frequencyValue       String?
  durationValue        Float?
  durationUnit         String?
  instructions         String?

  // Additional
  storageInstructions  String?
  warnings            String?
  pharmacyNotes       String?

  // Cost
  totalCost           Float?

  // Reference & Status
  referenceNumber     String    @unique
  preparedBy          String?
  preparedAt          DateTime?
  expiryDate          DateTime?

  // Metadata
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  ingredients         CompoundIngredient[]
  visit               Visit     @relation(fields: [visitId], references: [id])
  patient             Patient   @relation(fields: [patientId], references: [id])
  doctor               User      @relation(fields: [doctorId], references: [id])
}

model CompoundIngredient {
  id                      Int                  @id @default(autoincrement())
  compoundPrescriptionId  Int
  ingredientName          String
  strength                Float
  unit                    String    // %, mg/g, mg/ml
  isManualEntry           Boolean   @default(false)
  cost                    Float?
  sortOrder               Int       @default(0)

  compoundPrescription    CompoundPrescription  @relation(fields: [compoundPrescriptionId], references: [id], onDelete: Cascade)
}

model DispenseLog {
  id         Int             @id @default(autoincrement())
  orderId    Int
  patientId  String
  pharmacyId String
  quantity   Int
  notes      String?
  createdAt  DateTime        @default(now())
  order      MedicationOrder @relation(fields: [orderId], references: [id])
  patient    Patient         @relation(fields: [patientId], references: [id])
  pharmacy   User            @relation(fields: [pharmacyId], references: [id])
}

model LabOrder {
  id              Int               @id @default(autoincrement())
  visitId         Int?
  patientId       String
  doctorId        String?
  typeId          Int
  instructions    String?
  result          String?
  additionalNotes String?
  status          OrderStatus       @default(UNPAID)
  isWalkIn        Boolean           @default(false)
  billingId       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attachments     File[]            @relation("LabOrderFiles")
  doctor          User?             @relation(fields: [doctorId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  type            InvestigationType @relation(fields: [typeId], references: [id])
  visit           Visit?            @relation(fields: [visitId], references: [id])
  labResults      LabResult[]
  billing         Billing?          @relation(fields: [billingId], references: [id])
}

model RadiologyOrder {
  id               Int               @id @default(autoincrement())
  visitId          Int?
  patientId        String
  doctorId         String?
  typeId           Int
  instructions     String?
  result           String?
  status           OrderStatus       @default(UNPAID)
  isWalkIn         Boolean           @default(false)
  billingId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attachments      File[]            @relation("RadiologyOrderFiles")
  doctor           User?             @relation(fields: [doctorId], references: [id])
  patient          Patient           @relation(fields: [patientId], references: [id])
  type             InvestigationType @relation(fields: [typeId], references: [id])
  visit            Visit?            @relation(fields: [visitId], references: [id])
  radiologyResults RadiologyResult[]
}

model PathologyReport {
  id                     String                  @id @default(uuid())
  patientId              String
  visitId                Int?
  doctorId               String?
  sampleId               String?
  pathologyNo            String?
  receiptNo              String?
  reportDate             DateTime?
  reportStatus           PathologyReportStatus   @default(DRAFT)
  grossFinding           String?
  microscopy             String?
  conclusion             String?
  recommendation         String?
  natureOfSpecimen       String?
  durationOfLesion       String?
  infiltrationSign       String?
  symptomsSigns          String?
  lmp                    String?
  relevantLabData        String?
  pathologistName        String?
  pathologistSignature   String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([patientId])
  @@index([visitId])
  @@index([doctorId])
}

model NurseWalkInOrder {
  id           Int         @id @default(autoincrement())
  patientId    String
  serviceId    String
  nurseId      String?
  instructions String?
  notes        String?
  status       OrderStatus @default(UNPAID)
  billingId    String?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  nurse        User?       @relation("NurseWalkInOrders", fields: [nurseId], references: [id])
  patient      Patient     @relation(fields: [patientId], references: [id])
  service      Service     @relation(fields: [serviceId], references: [id])
  visit        Visit?      @relation(fields: [visitId], references: [id])
  visitId      Int?

  @@index([patientId])
  @@index([serviceId])
  @@index([nurseId])
  @@index([status])
  @@index([billingId])
  @@index([createdAt])
}

model DoctorWalkInOrder {
  id           Int         @id @default(autoincrement())
  patientId    String
  serviceId    String
  doctorId     String?
  instructions String?
  notes        String?
  status       OrderStatus @default(UNPAID)
  billingId    String?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  doctor       User?       @relation("DoctorWalkInOrders", fields: [doctorId], references: [id])
  patient      Patient     @relation(fields: [patientId], references: [id])
  service      Service     @relation(fields: [serviceId], references: [id])
  visit        Visit?      @relation(fields: [visitId], references: [id])
  visitId      Int?

  @@index([patientId])
  @@index([serviceId])
  @@index([doctorId])
  @@index([status])
  @@index([billingId])
  @@index([createdAt])
}

model EmergencyDrugOrder {
